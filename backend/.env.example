DB_HOST=localhost
DB_PORT=6432
DB_NAME=qvs_benchmarks
DB_USER=qvs
DB_PASSWORD=qvs

# Engine selection (strategy pattern - swap without code changes)
# CLASSICAL_ENGINE=brute_force_cosine    # or: faiss_flat_l2, faiss_hnsw_l2
# QUANTUM_ENGINE=quantum_mock_sampler    # or: qiskit_swap_test
# SEARCH_DIMENSION=64
# SEARCH_SHOTS=1024
# SEARCH_LAYERS=1
# SEARCH_TOP_K=10
# CLIP_MODEL=ViT-B/32
# CLIP_DEVICE=                           # auto-detect (cuda > mps > cpu)

# IBM Quantum real-hardware access.
# Keep IBM_QUANTUM_ALLOW_PAID=false unless you intentionally want paid Runtime usage.
# IBM_QUANTUM_TOKEN=
# IBM_QUANTUM_INSTANCE=crn:v1:bluemix:public:quantum-computing:us-east:...
# IBM_QUANTUM_BACKEND=least_busy
# IBM_QUANTUM_ALLOW_PAID=false
