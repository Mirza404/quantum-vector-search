# Copy this file to backend/.env and adjust for your environment.

# QVS_BENCHMARK_DSN
# PostgreSQL connection string used by DatabaseStorage to persist benchmark results.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# The default matches the Docker Compose setup in db/docker-compose.yml.
# Change host/port if you run Postgres outside of Docker.
QVS_BENCHMARK_DSN=postgresql://qvs:qvs@localhost:6432/qvs_benchmarks
